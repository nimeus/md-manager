# Copy to .env.local for local dev:  cp .env.local.example .env.local

# Upstream Rust API base URL. Fixed by the SERVER operator (not client-supplied) so a user
# can't make the BFF fetch an arbitrary host (no SSRF). Must match where `mdm-api` listens.
MDM_API_URL=http://127.0.0.1:8080

# --- Google sign-in (required for login) ---
# From Google Cloud Console → APIs & Services → Credentials → OAuth client ID (Web app).
# Authorized redirect URI must include:  http://localhost:3000/auth/callback
# The CLIENT ID must match the API's MDM_GOOGLE_CLIENT_ID (the API verifies Google tokens
# against it). The SECRET stays only on this Next.js server.
MDM_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
MDM_GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxx
