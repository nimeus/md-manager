# Rust
/target
**/*.rs.bk
*.pdb

# Env / secrets
.env
.env.*
!.env.example
*.pem
# …but the throwaway RSA key used to sign JWTs in unit tests must be committed
# (oauth.rs / google.rs include_str! it, so tests + clippy --all-targets need it).
!apps/api/tests/fixtures/test_key.pem

# Node / Next.js
node_modules/
frontend/.next/
frontend/out/
frontend/build/
.pnpm-store/
# stray npm artifact if npm is ever run from the repo root (frontend has its own)
/package-lock.json

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.swp

# Logs / local data
*.log
/data
/pgdata
