# md-manager API configuration (copy to .env or `source` it).
# The CLI/MCP use MDM_API_URL + MDM_API_KEY instead of these.

# App runtime role (md_app: non-owner, NOBYPASSRLS)
MDM_DATABASE_URL=postgres://md_app:md_app_dev@localhost:5432/md_manager
# Owner/migrator role (runs migrations on startup)
MDM_MIGRATION_DATABASE_URL=postgres://md_owner:md_owner_dev@localhost:5432/md_manager
# Optional: a SUPERUSER url used once at boot to auto-create the md_owner/md_app roles above
# (handy on managed Postgres — no manual SQL). Point it at the app database. Omit to set up
# the roles yourself (see scripts/db-roles.sql).
# MDM_SETUP_DATABASE_URL=postgres://postgres:superpw@localhost:5432/md_manager

# Server-side pepper for API-key/share-token HMAC. CHANGE IN PRODUCTION.
MDM_API_KEY_PEPPER=dev-insecure-pepper-change-me
# Token gating the dev bootstrap endpoint. CHANGE IN PRODUCTION.
MDM_ADMIN_BOOTSTRAP_TOKEN=dev-bootstrap-token

MDM_API_ADDR=127.0.0.1:8080
MDM_LOG_FORMAT=pretty
MDM_DB_MAX_CONNECTIONS=10
MDM_MAX_DOC_BYTES=1000000
MDM_AUTOSAVE_DEBOUNCE_SECS=30
# Abuse guards
MDM_MAX_DOCS_PER_PROJECT=5000
MDM_RATE_LIMIT_PER_MINUTE=120

# --- Web sign-in (Google + web sessions) for the Next.js app ---
# Set the Google client id to enable POST /v1/auth/google (verifies Google ID tokens server-
# side, aud == this). The frontend (Auth.js) uses the same id/secret. CHANGE the session secret.
# MDM_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
MDM_SESSION_SECRET=dev-insecure-session-secret-change-me
# MDM_SESSION_TTL_SECS=2592000   # 30 days

# --- Native connector: built-in OAuth 2.1 authorization server (Claude.ai / ChatGPT) ---
# Set MDM_OAUTH_MODE=builtin to make the API its own OAuth provider, so md-manager can be added
# as a custom connector with a Google sign-in (no external IdP). See docs/oauth-builtin.md.
# MDM_PUBLIC_URL=https://mdm-api.example.com   # this API's public origin (resource = <this>/mcp)
# MDM_OAUTH_MODE=builtin
# MDM_WEB_URL=https://mdm.example.com          # web app origin (hosts the /oauth/consent page)
# Token lifetimes (seconds) — defaults shown:
# MDM_OAUTH_ACCESS_TTL_SECS=3600
# MDM_OAUTH_REFRESH_TTL_SECS=2592000
# MDM_OAUTH_CODE_TTL_SECS=60
# MDM_OAUTH_REQUEST_TTL_SECS=600
# MDM_OAUTH_DCR_PER_HOUR=20                     # Dynamic Client Registration limit per IP
#
# Alternative: validate RS256 JWTs from an EXTERNAL issuer (Logto) instead. Leave MDM_OAUTH_MODE
# off and set these. See docs/oauth-logto.md.
# MDM_OAUTH_ISSUER=https://logto.example.com/oidc
# MDM_OAUTH_JWKS_URL=https://logto.example.com/oidc/jwks
# MDM_OAUTH_AUDIENCE=https://mdm-api.example.com/mcp
# MDM_OAUTH_ORG_CLAIM=org

# --- Embeddings / semantic search (optional, OpenAI-compatible) ---
# Requires `CREATE EXTENSION vector;` (superuser) in the DB once. See docs/embeddings.md.
# MDM_EMBEDDING_ENABLED=true
# MDM_EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
# MDM_EMBEDDING_API_KEY=sk-...
# MDM_EMBEDDING_MODEL=openai/text-embedding-3-small
# MDM_EMBEDDING_DIMENSIONS=1536
# MDM_EMBEDDING_BATCH_SIZE=32
# MDM_EMBEDDING_TIMEOUT_SECS=30
# MDM_EMBEDDING_WORKER_INTERVAL_SECS=10
# MDM_EMBEDDING_BACKOFF_BASE_SECS=30   # retry backoff base: delay = base * 2^attempts
# MDM_EMBEDDING_MAX_ATTEMPTS=8         # dead-letter a chunk after this many failures (0 = never)
# MDM_EMBEDDING_REFERER=https://your-app.example.com
# MDM_EMBEDDING_TITLE=md-manager

# RUST_LOG=info,mdm_api=debug,sqlx=warn
