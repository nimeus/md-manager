# md-manager API configuration (copy to .env or `source` it).
# The CLI/MCP use MDM_API_URL + MDM_API_KEY instead of these.

# App runtime role (md_app: non-owner, NOBYPASSRLS)
MDM_DATABASE_URL=postgres://md_app:md_app_dev@localhost:5432/md_manager
# Owner/migrator role (runs migrations on startup)
MDM_MIGRATION_DATABASE_URL=postgres://md_owner:md_owner_dev@localhost:5432/md_manager

# Server-side pepper for API-key/share-token HMAC. CHANGE IN PRODUCTION.
MDM_API_KEY_PEPPER=dev-insecure-pepper-change-me
# Token gating the dev bootstrap endpoint. CHANGE IN PRODUCTION.
MDM_ADMIN_BOOTSTRAP_TOKEN=dev-bootstrap-token

MDM_API_ADDR=127.0.0.1:8080
MDM_LOG_FORMAT=pretty
MDM_DB_MAX_CONNECTIONS=10
MDM_MAX_DOC_BYTES=1000000
MDM_AUTOSAVE_DEBOUNCE_SECS=30

# --- OAuth 2.1 resource server for the remote MCP endpoint (optional) ---
# Set all three to enable JWT auth on /mcp (web connectors). See docs/oauth-logto.md.
# MDM_PUBLIC_URL=https://md.example.com
# MDM_OAUTH_ISSUER=https://logto.example.com/oidc
# MDM_OAUTH_JWKS_URL=https://logto.example.com/oidc/jwks
# MDM_OAUTH_AUDIENCE=https://md.example.com
# MDM_OAUTH_ORG_CLAIM=org

# RUST_LOG=info,mdm_api=debug,sqlx=warn
